  .corehub { fill: var(--signal); }
  .axis { fill: none; stroke: var(--ink-faint); stroke-width: 0.7; stroke-dasharray: 6 3 2 3; opacity: 0.55; }
  .lead { fill: none; stroke: var(--ink-faint); stroke-width: 0.7; }
  .dim { fill: none; stroke: var(--ink-faint); stroke-width: 0.9; }
