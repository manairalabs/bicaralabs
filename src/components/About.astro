---
// About page — company E-E-A-T. The trust signal is the PRACTICE (approach,
// method, capabilities), not a named individual. Keep every claim factual.
import { BRAND } from '../config/author';
import { localize } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;

const copy = {
  en: {
    tag: 'About',
    title: 'A vendor-neutral AI enablement practice',
    lead: 'Bicara Labs helps businesses in Indonesia decide where AI actually pays off, deploy it securely on their own infrastructure, and build the custom pieces that off-the-shelf tools do not cover.',
    stanceTag: 'How we work',
    stance: [
      'We are vendor-neutral by design. The right model and the right infrastructure are whatever fit your data, budget, and risk tolerance — not whatever a single vendor is selling.',
      'We work hands-on across the stack: framing the business case for AI, shipping retrieval-augmented systems and LLM deployments into production, and building WhatsApp-first agents where that is where your customers already are.',
      'Two enterprise concerns lead every engagement — budget and security. Your data stays on your own infrastructure, private or self-hosted, with the controls your compliance needs.',
    ],
    focusTitle: 'Areas of focus',
    ctaText: 'Have a project in mind?',
    ctaLink: 'Book a discovery call',
  },
  id: {
    tag: 'Tentang',
    title: 'Praktik AI enablement yang vendor-neutral',
    lead: 'Bicara Labs membantu bisnis di Indonesia menentukan di mana AI benar-benar memberi hasil, menerapkannya secara aman di infrastruktur mereka sendiri, dan membangun bagian custom yang tidak dicakup alat siap pakai.',
    stanceTag: 'Cara kami bekerja',
    stance: [
      'Kami vendor-neutral secara prinsip. Model dan infrastruktur yang tepat adalah yang paling cocok dengan data, anggaran, dan toleransi risiko Anda — bukan yang sedang dijual satu vendor.',
      'Kami bekerja langsung di seluruh stack: menyusun business case untuk AI, membawa sistem retrieval-augmented dan deployment LLM ke produksi, serta membangun agent berbasis WhatsApp di tempat pelanggan Anda sudah berada.',
      'Dua hal jadi perhatian utama setiap proyek — anggaran dan keamanan. Data Anda tetap di infrastruktur sendiri, privat atau self-hosted, dengan kontrol sesuai kebutuhan kepatuhan Anda.',
    ],
    focusTitle: 'Area fokus',
    ctaText: 'Punya proyek dalam pikiran?',
    ctaLink: 'Jadwalkan konsultasi',
  },
}[lang];
---

<section class="section about-section">
  <div class="wrap about-wrap">
    <div class="section-tag">{copy.tag}</div>
    <h1 class="section-title">{copy.title}</h1>
    <p class="about-lead">{copy.lead}</p>

    <div class="about-stance">
      <div class="section-tag">{copy.stanceTag}</div>
      {copy.stance.map((p) => <p class="about-bio">{p}</p>)}

      <div class="about-knows">
        <div class="about-knows-title">{copy.focusTitle}</div>
        <ul class="about-knows-list">
          {BRAND.knowsAbout.map((k) => <li>{k}</li>)}
        </ul>
      </div>
    </div>

    <p class="about-cta">
      {copy.ctaText} <a href={localize('/contact', lang)}>{copy.ctaLink} →</a>
    </p>
  </div>
</section>

<style>
  .about-section { padding-top: 120px; }
  .about-wrap { max-width: 720px; }
  .about-lead { color: var(--ink-soft); font-size: 19px; line-height: 1.6; margin: 12px 0 48px; }
  .about-stance { border-top: 1px solid var(--line); padding-top: 32px; }
  .about-bio { color: var(--ink-soft); line-height: 1.65; margin: 0 0 16px; }
  .about-knows { margin-top: 28px; }
  .about-knows-title { font-family: var(--font-mono); font-size: 12px; color: var(--ink-faint); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px; }
  .about-knows-list { display: flex; flex-wrap: wrap; gap: 8px; list-style: none; padding: 0; margin: 0; }
  .about-knows-list li { font-family: var(--font-mono); font-size: 12px; color: var(--ink-soft); border: 1px solid var(--line); border-radius: 4px; padding: 6px 10px; }
  .about-cta { margin-top: 44px; font-size: 16px; }
  .about-cta a { color: var(--signal-ink); text-decoration: underline; text-underline-offset: 2px; }
</style>
