---
import Layout from '../../layouts/Layout.astro';
import About from '../../components/About.astro';
import { BRAND } from '../../config/author';

const site = Astro.site ?? new URL('https://bicaralabs.com');
const abs = (p: string) => new URL(p, site).href;

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: abs('/id/about'),
  mainEntity: {
    '@type': 'Organization',
    name: BRAND.name,
    url: abs('/'),
    knowsAbout: BRAND.knowsAbout,
  },
};
---

<Layout
  title="Tentang"
  description="Bicara Labs — praktik AI enablement vendor-neutral untuk bisnis di Indonesia. Strategi, deployment aman, dan pengembangan custom."
  breadcrumbs={[{ name: 'Tentang', href: '/id/about' }]}
>
  <About lang="id" />
  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />
</Layout>
