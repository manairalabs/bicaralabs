---
import Layout from '../layouts/Layout.astro';
import About from '../components/About.astro';
import { AUTHOR, authorPerson } from '../config/author';

const site = Astro.site ?? new URL('https://bicaralabs.com');
const abs = (p: string) => new URL(p, site).href;

const personSchema = {
  '@context': 'https://schema.org',
  ...authorPerson(abs),
  worksFor: { '@type': 'Organization', name: 'Bicara Labs', url: abs('/') },
};
---

<Layout
  title="About"
  description={`${AUTHOR.name} — ${AUTHOR.jobTitle}. Vendor-neutral AI enablement for businesses in Indonesia.`}
  breadcrumbs={[{ name: 'About', href: '/about' }]}
>
  <About lang="en" />
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
</Layout>
