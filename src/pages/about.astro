---
import Layout from '../layouts/Layout.astro';
import About from '../components/About.astro';
import { BRAND } from '../config/author';

const site = Astro.site ?? new URL('https://bicaralabs.com');
const abs = (p: string) => new URL(p, site).href;

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: abs('/about'),
  mainEntity: {
    '@type': 'Organization',
    name: BRAND.name,
    url: abs('/'),
    knowsAbout: BRAND.knowsAbout,
  },
};
---

<Layout
  title="About"
  description="Bicara Labs — a vendor-neutral AI enablement practice for businesses in Indonesia. Strategy, secure deployment, and custom builds."
  breadcrumbs={[{ name: 'About', href: '/about' }]}
>
  <About lang="en" />
  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />
</Layout>
